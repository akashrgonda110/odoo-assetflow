# =============================================================================
# AssetFlow — Root Environment Variables
# Copy this file to .env and fill in all required values before running
# docker compose up.
# =============================================================================

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DB_NAME=odoo_db
DB_USER=postgres
DB_PASSWORD=change_this_secure_password
DB_POOL_MIN=2
DB_POOL_MAX=10

# ─── JWT (generate strong random strings — minimum 32 characters each) ────────
JWT_ACCESS_SECRET=change_this_to_a_long_random_access_secret
JWT_REFRESH_SECRET=change_this_to_a_DIFFERENT_long_random_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Cookie ───────────────────────────────────────────────────────────────────
COOKIE_SECRET=change_this_to_a_long_random_cookie_secret

# ─── CORS — URL the browser uses to reach the frontend ────────────────────────
CLIENT_URL=http://localhost:3000

# ─── Rate limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── Frontend — URL the browser uses to reach the backend API ─────────────────
# This is baked into the Next.js client bundle at build time.
# For local Docker: http://localhost:5000/api
# For production:   https://api.yourdomain.com/api
NEXT_PUBLIC_API_URL=http://localhost:5000/api
